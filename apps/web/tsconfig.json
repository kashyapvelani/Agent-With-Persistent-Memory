{
  "extends": "@workspace/typescript-config/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@workspace/ui": ["../../packages/ui/src/index.ts"],
      "@workspace/ui/*": ["../../packages/ui/src/*"],
      "@workspace/db": ["../../packages/db/src/index.ts"],
      "@workspace/github": ["../../packages/github/src/index.ts"],
      "@workspace/types": ["../../packages/types/src/index.ts"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "next.config.mjs",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
, "../../packages/ui/src/components/nav-main.tsx", "../../packages/ui/src/components/nav-projects.tsx", "../../packages/ui/src/components/nav-secondary.tsx", "../../packages/ui/src/components/nav-user.tsx"  ],
  "exclude": ["node_modules"]
}
